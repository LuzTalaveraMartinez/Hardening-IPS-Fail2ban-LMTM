# $Id: local.rules,v 1.11 2004/07/23 20:15:44 bmc Exp $
# ----------------
# LOCAL RULES
# ----------------
# This file intentionally does not come with signatures.  Put your local
# additions here.
alert icmp any any -> $HOME_NET any (msg:"ALERTA LMTM: Intento de PING detectado"; sid:1000001; rev:1;)
alert tcp any any -> any any (msg:"ESCANEO DETECTADO"; flags:S; threshold:type threshold, track by_src, count 2, seconds 60; sid:1000002; rev:2;)
alert tcp any any -> $HOME_NET 22 (msg:"ALERTA LMTM: Posible Brute Force SSH"; flags:S; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000003; rev:1;)
